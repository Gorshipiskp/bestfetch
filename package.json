{
  "name": "bestfetch-g",
  "version": "2.1.0",
  "description": "Advanced fetch wrapper with retry mechanism, middleware support, TypeScript strong types, and intelligent error handling",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gorshipiskp/bestfetch.git"
  },
  "keywords": [
    "fetch",
    "http",
    "https",
    "api",
    "json",
    "typescript",
    "requests",
    "network",
    "retry",
    "middleware",
    "plugin",
    "callbacks"
  ],
  "author": "Gorshipisk",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
